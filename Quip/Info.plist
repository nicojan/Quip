         GitHub Pages from this repo's /docs folder (nicojan/Quip, public). -->
    <key>SUFeedURL</key>
    <string>https://nicojan.github.io/Quip/appcast.xml</string>
    <key>SUPublicEDKey</key>
    <string>6/h2Pfjbo39vHie8JIt/kY7h0wQvmQxj9Ea0W3gnH0w=</string>
    <key>SUEnableAutomaticChecks</key>
    <true/>
    <key>SUScheduledCheckInterval</key>
    <integer>86400</integer>
</dict>
</plist>
